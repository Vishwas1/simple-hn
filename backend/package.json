{
  "name": "simple-hn-backend",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "postinstall": "patch-package",
  "type": "module",
  "scripts": {
    "dev": "source ~/.bash_profile && nvm use 20 && tsx --conditions=node src/index.ts",
    "build": "npm run lint && npm run format && tsc -p tsconfig.json",
    "check": "npm run lint && npm run format:check && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"tsconfig.json\" \"package.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"tsconfig.json\" \"package.json\"",
    "prepare": "husky",
    "dev:mcp:http": "source ~/.bash_profile && nvm use 20 && tsx --conditions=node src/ccd-kb/mcp/http-index.ts",
    "dev:mcp:stdio": "source ~/.bash_profile && nvm use 20 && tsx --conditions=node src/ccd-kb/mcp/stdio-index.ts",
    "start:mcp:stdio": "node dist/ccd-kb/mcp/stdio-index.js"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "defuddle": "^0.15.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsdom": "^29.0.2",
    "langchain": "^1.2.37",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.4.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
